source ../../scripts/switch-terraform-version.sh
export TF_CLI_ARGS_init="-backend-config=\"assume_role={role_arn=\\\"arn:aws:iam::311462405659:role/operator\\\"}\" -upgrade -reconfigure"
export TF_WORKSPACE=development
export TF_VAR_default_role=breakglass
export TF_VAR_pagerduty_api_key=$(aws-vault exec management-operator -- aws secretsmanager get-secret-value --secret-id pagerduty-org-level-token | jq -r .'SecretString')
